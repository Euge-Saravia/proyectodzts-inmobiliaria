# Sanity Studio (SANITY_STUDIO_ prefix required for Vite)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=development

# Studio hosting (required for unattended `sanity deploy` in CI)
# SANITY_STUDIO_HOSTNAME: subdomain on *.sanity.studio (e.g. "my-studio")
# SANITY_STUDIO_APP_ID: app ID from sanity.io/manage → Studios; pins the
# version channel selector (Latest/Next/Stable) to this app
SANITY_STUDIO_HOSTNAME=your_studio_hostname
SANITY_STUDIO_APP_ID=your_studio_app_id
